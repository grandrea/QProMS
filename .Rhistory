dplyr::select(all_of(c("gene_names", p_val, fc))) %>%
View()
r6$stat_table %>%
dplyr::select(all_of(c("gene_names", p_val, fc))) %>%
dplyr::mutate(!!p_val := -log10(!!p_val)) %>%
View()
r6$stat_table %>%
dplyr::select(all_of(c("gene_names", p_val, fc))) %>%
mutate(across(ends_with(c("p_val")), ~ -log10(.))) %>%
View()
r6$stat_table %>%
dplyr::select(all_of(c("gene_names", p_val, fc))) %>%
mutate(across(ends_with(c("p_val")), ~ -log10(.))) %>%
mutate(across(ends_with(c("fold_change")), ~ sign(.))) %>%
View()
r6$stat_table %>%
dplyr::select(all_of(c("gene_names", p_val, fc))) %>%
mutate(across(ends_with(c("p_val")), ~ -log10(.))) %>%
mutate(across(ends_with(c("fold_change")), ~ sign(.))) %>%
dplyr::mutate(log_10_p_val = !!p_val * !!fc) %>%
View()
r6$stat_table %>%
dplyr::select(all_of(c("gene_names", p_val, fc))) %>%
mutate(across(ends_with(c("p_val")), ~ -log10(.))) %>%
mutate(across(ends_with(c("fold_change")), ~ sign(.))) %>%
dplyr::mutate(log_10_p_val = {{p_val}} * {{fc}}) %>%
View()
r6$stat_table %>%
dplyr::select(all_of(c("gene_names", p_val, fc))) %>%
mutate(across(ends_with(c("p_val")), ~ -log10(.))) %>%
mutate(across(ends_with(c("fold_change")), ~ sign(.))) %>%
dplyr::mutate(log_10_p_val = !!sym(p_val) * !!sym(fc)) %>%
View()
r6$stat_table %>%
dplyr::select(all_of(c("gene_names", p_val, fc))) %>%
mutate(across(ends_with(c("p_val")), ~ -log10(.))) %>%
mutate(across(ends_with(c("fold_change")), ~ sign(.))) %>%
dplyr::mutate(score = !!sym(p_val) * !!sym(fc)) %>%
arrange(desc(score)) %>%
dplyr::select(gene_names, score) %>%
View()
