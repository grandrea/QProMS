#     "nonXL_1 MaxLFQ Intensity",
#     "nonXL_2 MaxLFQ Intensity",
#     "nonXL_3 MaxLFQ Intensity"
#   )
# )
a <- tibble(
"condition" = c(
"control",
"control",
"control",
"treated",
"treated",
"treated"
),
"key" = c(
"Abundance: F1: Control, Control, 1",
"Abundance: F2: Control, Control, 2",
"Abundance: F3: Control, Control, 3",
"Abundance: F4: Sample, Treated, 4",
"Abundance: F5: Sample, Treated, 5",
"Abundance: F6: Sample, Treated, 6"
)
)
r6$validate_expdesign(a)
r6$add_replicate_and_label(a)
r6$preprocessing()
r6$protein_rank_target <- r6$expdesign$label[1]
r6$shiny_wrap_workflow()
# r6$plot_pca(FALSE)
r6$contrasts <- "control_vs_treated"
r6$stat_uni_test(test = "control_vs_treated", fc = 1, alpha = 0.05, p_adj_method = "BH", paired_test = FALSE, test_type = "welch")
r6$go_ora(
list_from = "univariate",
database = "KEGG",
focus = c("control_vs_treated_up", "control_vs_treated_down"),
ontology = r6$go_ora_term,
simplify_thr = r6$go_ora_simplify_thr,
alpha = r6$go_ora_alpha,
p_adj_method = r6$go_ora_p_adj_method,min_gs_size = 10,max_gs_size = 500,
background = r6$go_ora_background
)
r6$go_ora(
list_from = "univariate",
database = "GO",
focus = c("control_vs_treated_up", "control_vs_treated_down"),
ontology = r6$go_ora_term,
simplify_thr = r6$go_ora_simplify_thr,
alpha = r6$go_ora_alpha,
p_adj_method = r6$go_ora_p_adj_method,min_gs_size = 10,max_gs_size = 500,
background = r6$go_ora_background
)
r6$ora_table
