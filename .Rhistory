database = "WikiPathways",
ontology = "BP",
simplify_thr = 1,
alpha = 0.05,
p_adj_method = "BH",
min_gs_size = 10,
max_gs_size = 500
)
r6$go_gsea(
test = "xl_vs_non",
rank_type = "fc",
by_condition = FALSE,
database = "KEGG",
ontology = "BP",
simplify_thr = 1,
alpha = 0.05,
p_adj_method = "BH",
min_gs_size = 10,
max_gs_size = 500
)
xx <- compareCluster(r6$gsea_result_list$xl_vs_non, fun="enrichKEGG",
organism="hsa", pvalueCutoff=0.05)
r6$go_ora(
list_from = "univariate",
database = "KEGG",
focus = c("xl_vs_non_up", "xl_vs_non_down"),
ontology = r6$go_ora_term,
simplify_thr = r6$go_ora_simplify_thr,
alpha = r6$go_ora_alpha,
p_adj_method = r6$go_ora_p_adj_method,min_gs_size = 10,max_gs_size = 500,
background = r6$go_ora_background
)
xx <- compareCluster(r6$ora_result_list$xl_vs_non_down@geneSets, fun="enrichKEGG",
organism="hsa", pvalueCutoff=0.05)
dotplot(xx)
xx <- compareCluster(
list(down = r6$ora_result_list$xl_vs_non_down@geneSets, up = r6$ora_result_list$xl_vs_non_up@geneSets),
fun = "enrichKEGG",
organism = "hsa",
pvalueCutoff = 0.05
)
xx <- compareCluster(
list(down = r6$ora_result_list$xl_vs_non_up@geneSets, up = r6$ora_result_list$xl_vs_non_up@geneSets),
fun = "enrichKEGG",
organism = "hsa",
pvalueCutoff = 0.05
)
dotplot(xx)
xx <- compareCluster(
r6$ora_result_list$xl_vs_non_up@geneSets,
fun = "enrichKEGG",
organism = "hsa",
pvalueCutoff = 0.05
)
dotplot(xx)
