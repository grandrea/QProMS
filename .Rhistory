r6$make_expdesign(intensity_type = "Abundance:")
# a <- tibble(
#   "condition" = c("xl", "xl", "xl", "non", "non", "non"),
#   "key" = c(
#     "XL_1 MaxLFQ Intensity",
#     "XL_2 MaxLFQ Intensity",
